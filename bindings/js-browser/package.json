{
  "name": "js-browser",
  "version": "1.0.0",
  "source": "src/index.ts",
  "type": "module",
  "scripts": {
    "build:wasm": "emcmake cmake -S$(pwd)/../.. -B$(pwd)/build && cmake --build $(pwd)/build --parallel",
    "build:js": "rollup -c",
    "build": "${npm_execpath} run build:wasm && ${npm_execpath} run build:js",
    "start": "DEV_SERVER=ON ${npm_execpath} run build:wasm && rollup -c --watch",
    "test": "playwright test"
  },
