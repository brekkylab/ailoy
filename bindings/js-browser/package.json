  "description": "",
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@rollup/plugin-commonjs": "^28.0.3",
    "rollup": "^4.35.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-serve": "^3.0.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "typescript": "^5.8.2"
  }
}
